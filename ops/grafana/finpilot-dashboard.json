{
  "title": "FinPilot — RED + Domain",
  "uid": "finpilot-red",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(finpilot_http_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(finpilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(finpilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(finpilot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors by code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (code) (rate(finpilot_http_errors_total[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ledger integrity violations (MUST be 0)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(finpilot_ledger_integrity_violations_total)" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DLQ depth",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "expr": "sum(finpilot_dlq_depth)" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Journal entries posted",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [{ "expr": "rate(finpilot_journal_entries_posted_total[15m])" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "AI tokens + grounding failures",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "targets": [
        { "expr": "rate(finpilot_ai_tokens_consumed_total[15m])", "legendFormat": "tokens/s" },
        {
          "expr": "increase(finpilot_ai_grounding_failures_total[1h])",
          "legendFormat": "grounding failures (1h)"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue job duration p95 by queue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (queue, le) (rate(finpilot_queue_job_duration_seconds_bucket[10m])))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rate-limit rejections by scope",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (scope) (rate(finpilot_rate_limit_rejections_total[5m]))",
          "legendFormat": "{{scope}}"
        }
      ]
    }
  ]
}
