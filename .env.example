# Copy to .env.local (gitignored) — or run `pnpm setup:env` to do it with generated secrets.
# apps/api/src/config/env.ts validates all of this through Zod and REFUSES TO BOOT on anything
# missing or malformed. See plan.md Appendix A for the full production variable list.

NODE_ENV=development
PROCESS_TYPE=api                 # api | ws | worker
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000

# Mongo MUST be a replica set, even in dev (transactions depend on it).
MONGO_URI=mongodb://localhost:27017/finpilot?replicaSet=rs0&directConnection=true
MONGO_MAX_POOL=50
# FinPilot's dev redis is mapped to host 6380 (6379 is used by another local project)
REDIS_URL=redis://localhost:6380

# REQUIRED — no default, boot fails without it. 64 hex chars.
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# REQUIRED — AES-256-GCM key for TOTP secrets at rest. 64 hex chars.
# Production uses a KMS-held DEK instead (ENCRYPTION_KEK_ARN).
ENCRYPTION_KEY=
ARGON2_MEMORY_KIB=19456

# S3 / MinIO (docker-compose dev defaults)
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=finpilot-documents
S3_ACCESS_KEY=finpilot
S3_SECRET_KEY=finpilot-dev-secret
S3_REGION=ap-south-1

# Mail (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM="FinPilot <no-reply@finpilot.local>"

LOG_LEVEL=debug

# ── Optional integrations (features degrade gracefully when unset) ──────────
# Razorpay: webhook verify + payment capture + subscriptions (plan.md §28.3, §32 Phase 23)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_PLAN_ID_STARTER=
# RAZORPAY_PLAN_ID_PROFESSIONAL=
# RAZORPAY_PLAN_ID_ENTERPRISE=
# Sentry error capture (plan.md §27) — off unless a DSN is set
# SENTRY_DSN=
