{
  "name": "@finpilot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,worker -c blue,magenta \"cross-env PROCESS_TYPE=api tsx watch src/index.ts\" \"cross-env PROCESS_TYPE=worker tsx watch src/index.ts\"",
    "dev:api": "cross-env PROCESS_TYPE=api tsx watch src/index.ts",
    "dev:worker": "cross-env PROCESS_TYPE=worker tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sentry/node": "^10.67.0",
    "argon2": "^0.41.1",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.80.9",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.0",
    "nodemailer": "^6.10.0",
    "opossum": "^10.0.0",
    "otplib": "^12.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "mongodb-memory-server": "^10.1.4",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
