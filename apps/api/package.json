{
  "name": "@finpilot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,worker -c blue,magenta \"cross-env PROCESS_TYPE=api tsx watch src/index.ts\" \"cross-env PROCESS_TYPE=worker tsx watch src/index.ts\"",
    "dev:api": "cross-env PROCESS_TYPE=api tsx watch src/index.ts",
    "dev:worker": "cross-env PROCESS_TYPE=worker tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "ioredis": "^5.6.0",
    "mongoose": "^8.13.0",
    "pino": "^9.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
